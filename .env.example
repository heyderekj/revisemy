APP_NAME=ReviseMy
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Fathom analytics (leave empty to disable locally)
FATHOM_SITE_ID=SQIIUMVL

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Realtime: set BROADCAST_CONNECTION=reverb (and the REVERB_/VITE_REVERB_ vars
# below, plus `php artisan reverb:start`) for live board/mark updates. With
# "log" the UI still works but falls back to polling and shows a gray
# "Polling" badge instead of "Live".
BROADCAST_CONNECTION=log

# REVERB_APP_ID=revisemy
# REVERB_APP_KEY=
# REVERB_APP_SECRET=
# REVERB_HOST=localhost
# REVERB_PORT=8080
# REVERB_SCHEME=http
# VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
# VITE_REVERB_HOST="${REVERB_HOST}"
# VITE_REVERB_PORT="${REVERB_PORT}"
# VITE_REVERB_SCHEME="${REVERB_SCHEME}"
FILESYSTEM_DISK=public
REVISEMY_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Second opinion (Cloud-queued checklist; vision pass optional).
# Provider: auto (prefer Anthropic when its key is set, else OpenAI), anthropic, or openai.
REVISEMY_SECOND_OPINION=true
REVISEMY_VISION_PROVIDER=auto
ANTHROPIC_API_KEY=
REVISEMY_ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_API_KEY=
REVISEMY_OPENAI_MODEL=gpt-4o-mini
# Free local vision (Ollama / any OpenAI-compatible /v1). Blank key is OK for Ollama.
# REVISEMY_VISION_PROVIDER=openai
# REVISEMY_OPENAI_BASE_URL=http://localhost:11434/v1
# REVISEMY_OPENAI_MODEL=llama3.2-vision
# OPENAI_API_KEY=
# Hosted OpenAI-compatible (Groq, OpenRouter, LM Studio): set REVISEMY_OPENAI_BASE_URL + their API key.

# Server-side capture (optional): renders page_url / email HTML / PDFs into
# screenshots. hosted = Browserless-compatible API; browsershot = local Chrome.
# Driver must be the literal string hosted|browsershot — leave unset to disable;
# a blank Cloud env var is treated as off.
# Prefer images (data URLs) for localhost — saves Browserless units and user credits.
# REVISEMY_CAPTURE_DRIVER=hosted
# REVISEMY_CAPTURE_ENDPOINT=https://production-sfo.browserless.io/screenshot
# REVISEMY_CAPTURE_KEY=
# REVISEMY_CAPTURE_CONTENT_ENDPOINT=https://production-sfo.browserless.io/content
# REVISEMY_CAPTURE_TIMEOUT=60
# REVISEMY_CAPTURE_WAIT_MS=2500
# REVISEMY_CAPTURE_WAIT_UNTIL=networkidle2
# Walk the page so IntersectionObserver / scroll-in animations reveal before shot.
# REVISEMY_CAPTURE_SCROLL_PAGE=true
# REVISEMY_CAPTURE_SCROLL_TIMEOUT_MS=45000
# REVISEMY_CAPTURE_SCROLL_STEP_MS=175
# REVISEMY_CAPTURE_DPR=2
# Website URL capture: full scroll height at DPR 1 (HTML/email keep REVISEMY_CAPTURE_DPR).
# REVISEMY_CAPTURE_URL_FULL_PAGE=true
# REVISEMY_CAPTURE_URL_DPR=1

# Billing (Laravel Cashier Paddle). Try = 20 credits once; Plus = $9/mo + 100 credits.
# Create a $9/mo price in Paddle → paste pri_… as PADDLE_PRICE_PRO. Webhook: /paddle/webhook
# PADDLE_SANDBOX=true
# PADDLE_CLIENT_SIDE_TOKEN=test_…
# PADDLE_API_KEY=pdl_…
# PADDLE_WEBHOOK_SECRET=pdl_ntfset_…
# PADDLE_PRICE_PRO=pri_…
# REVISEMY_FREE_CREDITS=20
# REVISEMY_PRO_CREDITS=100
# REVISEMY_TRY_TOKEN_PER_HOUR=3
# REVISEMY_TRY_TOKEN_PER_DAY=3
